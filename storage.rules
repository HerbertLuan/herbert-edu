rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // É admin quem está autenticado e tem o custom claim admin=true.
    // O Admin SDK do script de publicação ignora estas regras.
    function ehAdmin() {
      return request.auth != null && request.auth.token.admin == true;
    }

    // Arquivos das aulas (HTML) e materiais (PDF): leitura pública,
    // escrita só pelo admin (upload pelo painel).
    match /aulas/{arquivo=**} {
      allow read: if true;
      allow write: if ehAdmin();
    }
    match /pdfs/{arquivo=**} {
      allow read: if true;
      allow write: if ehAdmin();
    }

    // Perguntas dos minigames (JSON): leitura pública, escrita só pelo admin.
    match /jogos/{arquivo=**} {
      allow read: if true;
      allow write: if ehAdmin();
    }

    match /{tudo=**} {
      allow read, write: if false;
    }
  }
}
